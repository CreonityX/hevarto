{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "admin.hevarto.com"
        }
      ],
      "destination": "/admin"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "admin.hevarto.com"
        }
      ],
      "destination": "/admin"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
